<script>
let currentTab = '<?= $active_tab ?>';

// Switch between tabs
function switchTab(tab) {
  currentTab = tab;

  // Update URL without reload
  const url = new URL(window.location);
  url.searchParams.set('tab', tab);
  window.history.pushState({}, '', url);

  // Update tab button styles
  document.querySelectorAll('.tab-button').forEach(btn => {
    btn.classList.remove('bg-yellow-600', 'bg-red-600', 'bg-teal-600', 'text-white', 'shadow-lg');
    btn.classList.add('bg-gray-100', 'text-gray-700');
  });

  const activeBtn = document.getElementById(`tab-${tab}`);
  activeBtn.classList.remove('bg-gray-100', 'text-gray-700');
  activeBtn.classList.add('text-white', 'shadow-lg');

  if (tab === 'job_edit') {
    activeBtn.classList.add('bg-yellow-600');
  } else if (tab === 'job_deletion') {
    activeBtn.classList.add('bg-red-600');
  } else {
    activeBtn.classList.add('bg-teal-600');
  }

  // Load content
  loadContent(tab);
}

// Load content based on tab
function loadContent(tab) {
  const contentDiv = document.getElementById('log-content');
  contentDiv.innerHTML = '<div class="text-center py-12"><div class="animate-spin rounded-full h-12 w-12 border-b-2 border-indigo-600 mx-auto"></div><p class="text-gray-500 mt-4">กำลังโหลดข้อมูล...</p></div>';

  // Fetch content from PHP include files
  fetch(`logs_content.php?tab=${tab}`)
    .then(response => response.text())
    .then(html => {
      contentDiv.innerHTML = html;
    })
    .catch(error => {
      contentDiv.innerHTML = `<div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-xl">
        <p class="font-medium">เกิดข้อผิดพลาดในการโหลดข้อมูล</p>
        <p class="text-sm">${error.message}</p>
      </div>`;
    });
}

// Load initial content
document.addEventListener('DOMContentLoaded', function() {
  loadContent(currentTab);
});
</script>

