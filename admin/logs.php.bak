<?php
require_once __DIR__ . '/../includes/session_config.php';
if ($_SESSION['user']['role'] !== 'admin') {
    header("Location: ../index.php");
    exit;
}
include '../config/db.php';

// Generate CSRF Token
if (empty($_SESSION['csrf_token'])) {
    $_SESSION['csrf_token'] = bin2hex(random_bytes(32));
}

// Handle POST requests for clearing logs
$alert_message = '';
$alert_type = '';

if ($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_POST['clear_logs'])) {
    // Verify CSRF token
    if (!isset($_POST['csrf_token']) || !hash_equals($_SESSION['csrf_token'], $_POST['csrf_token'])) {
        $alert_message = 'CSRF token validation failed';
        $alert_type = 'error';
    } else {
        // Double-check admin role
        if ($_SESSION['user']['role'] !== 'admin') {
            $alert_message = 'ไม่มีสิทธิ์ในการลบ Log (ต้องเป็นผู้ดูแลระบบเท่านั้น)';
            $alert_type = 'error';
        } else {
            $admin_pass = $_POST['admin_password'] ?? '';
            $admin_id = $_SESSION['user']['id'];

            // Verify admin password
            $stmt = $conn->prepare("SELECT password FROM users WHERE id = ? AND role = 'admin'");
            $stmt->bind_param("i", $admin_id);
            $stmt->execute();
            $stmt->bind_result($hash);
            $stmt->fetch();
            $stmt->close();

            if (!$hash) {
                $alert_message = 'ไม่พบข้อมูลผู้ดูแลระบบ';
                $alert_type = 'error';
            } elseif (!password_verify($admin_pass, $hash)) {
                $alert_message = 'รหัสผ่านไม่ถูกต้อง';
                $alert_type = 'error';
            } else {
                // Determine which table to clear based on log_type
                $log_type = $_POST['log_type'] ?? '';
                $success = false;

                $conn->begin_transaction();
                try {
                    switch ($log_type) {
                        case 'job_edit':
                            $success = $conn->query("DELETE FROM job_edit_logs");
                            break;
                        case 'login':
                            $success = $conn->query("TRUNCATE TABLE login_logs");
                            break;
                        case 'job_deletion':
                            $success = $conn->query("TRUNCATE TABLE job_deletion_logs");
                            break;
                        default:
                            throw new Exception('ประเภท log ไม่ถูกต้อง');
                    }

                    if ($success) {
                        $conn->commit();
                        $alert_message = 'ล้าง log เรียบร้อยแล้ว';
                        $alert_type = 'success';
                    } else {
                        throw new Exception('เกิดข้อผิดพลาดในการล้าง log');
                    }
                } catch (Exception $e) {
                    $conn->rollback();
                    $alert_message = $e->getMessage();
                    $alert_type = 'error';
                }
            }
        }
    }
}

// Get selected tab from URL (default: job_edit)
$active_tab = $_GET['tab'] ?? 'job_edit';
$allowed_tabs = ['job_edit', 'job_deletion', 'login'];
if (!in_array($active_tab, $allowed_tabs)) {
    $active_tab = 'job_edit';
}

// If there was a POST request, redirect to prevent form resubmission
if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    $_SESSION['alert_message'] = $alert_message;
    $_SESSION['alert_type'] = $alert_type;
    header("Location: logs.php?tab=" . $active_tab);
    exit;
}

// Retrieve alert from session if exists
if (isset($_SESSION['alert_message'])) {
    $alert_message = $_SESSION['alert_message'];
    $alert_type = $_SESSION['alert_type'];
    unset($_SESSION['alert_message']);
    unset($_SESSION['alert_type']);
}

$page_title = "ระบบจัดการ Logs";
include '../components/header.php';
?>

